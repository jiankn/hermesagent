{
  "name": "hermesagent-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run generate:sitemap",
    "dev": "next dev",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "build": "npm run generate:sitemap && next build",
    "start": "next start",
    "lint": "eslint",
    "pages:build": "npm run build && npx opennextjs-cloudflare",
    "preview": "npm run generate:sitemap && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run generate:sitemap && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "npm run generate:sitemap && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "audit:content": "node scripts/audit-content.mjs",
    "check:indexing": "node scripts/check-indexing.mjs"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "latest",
    "gray-matter": "^4.0.3",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "typescript": "^5",
    "wrangler": "latest"
  }
}
